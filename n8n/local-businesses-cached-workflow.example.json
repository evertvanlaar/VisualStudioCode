    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Geen webhook-context nodig. Na Execute: eerstvolgende hit op local-businesses haalt Sheets.\nconst sd = $getWorkflowStaticData('global');\ndelete sd.lbCacheRows;\ndelete sd.lbCacheExpires;\nreturn [\n  {\n    json: {\n      cleared: true,\n      hint: 'Roep nu /webhook/local-businesses aan (of ververs de site) voor verse Sheet-data.',\n    },\n  },\n];"
      },
