      "id": "wb-reset-cache",
      "name": "Webhook reset cache",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [-600, -260],
      "webhookId": "local-businesses-reset-cache"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Zelfde env als cache-bypass (of alleen deze): LB_CACHE_BYPASS_SECRET\n// Aanroep: GET .../webhook/local-businesses-reset-cache?token=JOUW_GEHEIM\n// Of header: X-Cache-Reset-Token: JOUW_GEHEIM\n\nconst item = $input.first().json;\nconst q = item.query || {};\nconst h = item.headers || {};\nconst secret = String($env.LB_CACHE_BYPASS_SECRET || '').trim();\nconst token = String(\n  q.token ?? q.secret ?? h['x-cache-reset-token'] ?? h['X-Cache-Reset-Token'] ?? '',\n).trim();\n\nif (!secret) {\n  return [{ json: { resetAllowed: false, reason: 'LB_CACHE_BYPASS_SECRET niet gezet op n8n' } }];\n}\n\nif (token !== secret) {\n  return [{ json: { resetAllowed: false, reason: 'forbidden' } }];\n}\n\nconst sd = $getWorkflowStaticData('global');\ndelete sd.lbCacheRows;\ndelete sd.lbCacheExpires;\n\nreturn [{ json: { resetAllowed: true } }];"
      },
