      "id": "wb-local-biz-001",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [-600, 0],
      "webhookId": "local-businesses"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// BELANGRIJK: $('Webhook') moet exact de naam zijn van je Webhook-node (bv. Webhook2).\n// Cache bypass (optioneel): env LB_CACHE_BYPASS_SECRET + header X-LB-Cache-Bypass of ?refresh=\n\nconst sd = $getWorkflowStaticData('global');\nconst h = $('Webhook').first().json.headers || {};\nconst q = $('Webhook').first().json.query || {};\nconst secret = String($env.LB_CACHE_BYPASS_SECRET || '').trim();\n\nconst headerVal = String(\n  h['x-lb-cache-bypass'] ?? h['X-LB-Cache-Bypass'] ?? '',\n).trim();\nconst qRefresh = q.refresh != null ? String(q.refresh).trim() : '';\n\nconst bypass =\n  secret.length > 0 &&\n  (headerVal === secret || qRefresh === secret);\n\nif (bypass) {\n  delete sd.lbCacheRows;\n  delete sd.lbCacheExpires;\n}\n\nconst now = Date.now();\n\nif (\n  sd.lbCacheRows &&\n  typeof sd.lbCacheExpires === 'number' &&\n  now < sd.lbCacheExpires &&\n  Array.isArray(sd.lbCacheRows)\n) {\n  return [{ json: { cacheHit: true, rows: sd.lbCacheRows } }];\n}\n\nreturn [{ json: { cacheHit: false } }];"
      },
